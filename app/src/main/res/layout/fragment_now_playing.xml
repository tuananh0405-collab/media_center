<?xml version="1.0" encoding="utf-8"?>
<!-- Now Playing Screen — matches design mockup -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    tools:context=".ui.nowplaying.NowPlayingFragment">

    <!-- Header: Back + "Now Playing" + Queue icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/now_playing"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:paddingStart="@dimen/spacing_sm" />

        <ImageButton
            android:id="@+id/btn_queue"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Queue"
            android:scaleType="centerInside" />

    </LinearLayout>

    <!-- Main Content: Album Art (left) + Track Info + Controls (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_xl">

        <!-- Large Album Art -->
        <ImageView
            android:id="@+id/image_album_art"
            android:layout_width="@dimen/album_art_now_playing"
            android:layout_height="@dimen/album_art_now_playing"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_album_art_placeholder"
            android:contentDescription="Album Art"
            android:clipToOutline="true"
            tools:src="@drawable/ic_launcher_foreground" />

        <!-- Track Info + Controls Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_xl">

            <!-- Track Title -->
            <TextView
                android:id="@+id/text_track_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Midnight City" />

            <!-- Artist — Album -->
            <TextView
                android:id="@+id/text_track_artist_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_subtitle"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="@dimen/spacing_xs"
                tools:text="M83 — Hurry Up, We're Dreaming" />

            <!-- Progress Bar -->
            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary"
                android:progressBackgroundTint="@color/progress_track"
                android:max="1000" />

            <!-- Time Labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_position"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption"
                    tools:text="0:04" />

                <TextView
                    android:id="@+id/text_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption"
                    tools:text="4:03" />

            </LinearLayout>

            <!-- Playback Controls Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_md">

                <!-- Shuffle -->
                <ImageButton
                    android:id="@+id/btn_shuffle"
                    android:layout_width="@dimen/control_button_size"
                    android:layout_height="@dimen/control_button_size"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/shuffle"
                    android:scaleType="centerInside"
                    app:tint="@color/text_secondary" />

                <!-- Previous -->
                <ImageButton
                    android:id="@+id/btn_prev"
                    android:layout_width="@dimen/control_button_size"
                    android:layout_height="@dimen/control_button_size"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/skip_previous"
                    android:scaleType="centerInside"
                    app:tint="@color/text_primary" />

                <!-- Play / Pause (large teal circle) -->
                <ImageButton
                    android:id="@+id/btn_play_pause"
                    android:layout_width="@dimen/play_pause_button_size"
                    android:layout_height="@dimen/play_pause_button_size"
                    android:src="@android:drawable/ic_media_pause"
                    android:background="@drawable/bg_play_button"
                    android:contentDescription="@string/play"
                    android:scaleType="centerInside"
                    app:tint="@color/text_on_primary" />

                <!-- Next -->
                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="@dimen/control_button_size"
                    android:layout_height="@dimen/control_button_size"
                    android:src="@android:drawable/ic_media_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/skip_next"
                    android:scaleType="centerInside"
                    app:tint="@color/text_primary" />

                <!-- Repeat -->
                <ImageButton
                    android:id="@+id/btn_repeat"
                    android:layout_width="@dimen/control_button_size"
                    android:layout_height="@dimen/control_button_size"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/repeat"
                    android:scaleType="centerInside"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
